# ============================================
# ChessMate Environment Configuration
# ============================================
# IMPORTANT: Copy this file to .env.local and fill in your actual values.
# Without proper configuration the app will NOT work correctly.

# ============================================
# REQUIRED: Supabase Configuration
# ============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# OPTIONAL: OAuth provider availability gates
# ============================================
# Defaults are false: an un-configured provider is hidden from the
# Sign In screen rather than shown as a guaranteed-to-fail button.
#
# Flip a flag to "true" ONLY after the provider is also configured in
# Supabase Dashboard → Authentication → Providers.

VITE_OAUTH_GOOGLE_ENABLED=false
VITE_OAUTH_GITHUB_ENABLED=false

# ============================================
# OPTIONAL: Sentry Error Monitoring
# ============================================
# Get from: https://sentry.io/
# Leave empty to disable monitoring.

VITE_SENTRY_DSN=

# ============================================
# SETUP CHECKLIST (MUST DO BEFORE RUNNING)
# ============================================
#
# □ 1. Create Supabase project at https://supabase.com
# □ 2. Apply database migrations:
#      npx supabase db push
#      (Creates: games, questions, game_analysis_results, user_statistics, api_logs tables)
#
# □ 3. Set Gemini API key as a Supabase secret (server-side only — NOT in .env):
#      npx supabase secrets set GEMINI_API_KEY=your_key_here
#
# □ 4. Deploy edge function:
#      npx supabase functions deploy chess-mentor
#
# □ 5. Set the allowed origins for the edge function (CORS):
#      npx supabase secrets set ALLOWED_ORIGINS=https://your-domain.com
#      Leave empty in development (all origins allowed).
#
# □ 6. (Optional) Configure OAuth providers in Supabase dashboard:
#      Authentication > Providers > Enable Google / GitHub
#      Add redirect URL: https://your-domain.com
#
# ============================================
# WHAT WON'T WORK WITHOUT CONFIGURATION
# ============================================
#
# Missing Supabase credentials:
#  ✗ Cannot log in or create an account
#  ✗ Cannot save or load games
#  ✗ Cannot view statistics
#  ✗ No data persistence
#
# Missing Gemini API secret + edge function:
#  ✗ AI chess coach won't respond
#  ✗ Chat interface will show errors
#
# Missing OAuth configuration:
#  ✗ Google / GitHub login buttons won't work
#  ✓ Email / password login still works
#
# ============================================
# E2E TESTS
# ============================================
#
# To run game-import tests, add credentials in .env.test:
#   PLAYWRIGHT_TEST_USER=test@example.com
#   PLAYWRIGHT_TEST_PASSWORD=testpassword
